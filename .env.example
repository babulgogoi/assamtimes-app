PORT=3000
NODE_ENV=development

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=assamtimes_db
DB_USER=assamtimes_user
DB_PASSWORD=changeme

# Site
SITE_URL=http://localhost:3000

# Session (generate your own: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
SESSION_SECRET=changeme

# Uploads (absolute paths on this host, served from public_html outside the app dir)
UPLOADS_ARTICLES_DIR=/home/assam1/web/new.assamtimes.org/public_html/uploads/articles
UPLOADS_AUDIO_DIR=/home/assam1/web/new.assamtimes.org/public_html/uploads/audio
UPLOADS_DOCUMENTS_DIR=/home/assam1/web/new.assamtimes.org/public_html/uploads/documents
UPLOADS_DEFAULTS_DIR=/home/assam1/web/new.assamtimes.org/public_html/uploads/defaults

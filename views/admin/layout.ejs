<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title : 'Admin' %></title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body class="admin-body">
  <header class="admin-header">
    <span class="admin-header__brand">Assam Times Admin</span>
    <nav class="admin-header__nav">
      <a href="/admin">Articles</a>
      <form method="post" action="/admin/logout" class="admin-header__logout">
        <button type="submit">Logout<% if (typeof authorName !== 'undefined' && authorName) { %> (<%= authorName %>)<% } %></button>
      </form>
    </nav>
  </header>
  <main class="admin-main">
    <%- body %>
  </main>
</body>
</html>

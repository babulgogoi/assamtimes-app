<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <% if (process.env.NODE_ENV === 'production') { %>
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-W3VCJYPSX0"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-W3VCJYPSX0');
    </script>
  <% } %>
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body class="admin-login-body">
  <form class="admin-login-form" method="post" action="/admin/login">
    <h1>Assam Times Admin</h1>
    <% if (error) { %>
      <p class="admin-login-form__error"><%= error %></p>
    <% } %>
    <label>
      Username
      <input type="text" name="username" autocomplete="username" required autofocus>
    </label>
    <label>
      Password
      <input type="password" name="password" autocomplete="current-password" required>
    </label>
    <button type="submit">Log In</button>
  </form>
</body>
</html>

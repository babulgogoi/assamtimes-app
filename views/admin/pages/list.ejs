<div class="admin-list-header">
  <h1>Pages</h1>
  <a class="admin-btn admin-btn--primary" href="/admin/pages/new">+ New Page</a>
</div>

<table class="admin-table">
  <thead>
    <tr>
      <th>Title</th>
      <th>Slug</th>
      <th>Status</th>
      <th>Updated</th>
      <th></th>
    </tr>
  </thead>
  <tbody>
    <% pages.forEach(function (page) { %>
      <tr>
        <td><a href="/admin/pages/<%= page.id %>/edit"><%= page.title %></a></td>
        <td><%= page.slug %></td>
        <td><span class="admin-badge admin-badge--<%= page.status %>"><%= page.status %></span></td>
        <td><%= page.updated_at ? new Date(page.updated_at).toLocaleDateString('en-IN') : '—' %></td>
        <td>
          <form method="post" action="/admin/pages/<%= page.id %>/delete" onsubmit="return confirm('Delete this page? This cannot be undone.');">
            <button type="submit" class="admin-btn admin-btn--danger">Delete</button>
          </form>
        </td>
      </tr>
    <% }) %>
    <% if (!pages.length) { %>
      <tr><td colspan="5">No pages found.</td></tr>
    <% } %>
  </tbody>
</table>

<div class="home-layout">
  <div class="home-main">
    <article class="article-detail">
      <% if (isAdmin) { %>
        <a class="admin-edit-link" href="/admin/articles/<%= article.id %>/edit">Edit this page</a>
      <% } %>

      <% if (article.category) { %>
        <a href="/category/<%= encodeURIComponent(article.category) %>" class="article-category"><%= article.category %></a>
      <% } %>

      <h1 class="article-detail__title"><%= article.title %></h1>

      <div class="article-byline">
        <% if (article.author_username) { %>
          <img class="article-meta__photo" src="<%= article.author_photo || '/uploads/defaults/avatar.png' %>" alt="">
        <% } %>
        <p class="article-meta">
          <% if (article.author_username) { %>
            <a href="/author/<%= encodeURIComponent(article.author_username) %>"><%= article.author_name %></a> &middot;
          <% } %>
          <% if (article.published_at) { %>
            <%= new Date(article.published_at).toLocaleDateString('en-IN', { year: 'numeric', month: 'long', day: 'numeric' }) %> &middot;
          <% } %>
          <%= article.views_count %> views
        </p>
      </div>

      <img class="article-detail__image" src="<%= article.featured_image || '/uploads/defaults/at-news.png' %>" alt="<%= article.featured_image_caption || article.title %>">
      <% if (article.featured_image_caption) { %>
        <p class="article-detail__image-caption"><%= article.featured_image_caption %></p>
      <% } %>

      <% if (article.excerpt) { %>
        <p class="article-detail__excerpt"><%= article.excerpt %></p>
      <% } %>

      <div class="article-detail__body">
        <%- article.body %>
      </div>

      <%- include('../partials/ads-in-article') %>

      <% if (article.gallery_images && article.gallery_images.length) { %>
        <% if (article.gallery_images.length === 1) { %>
          <% var soloImg = article.gallery_images[0]; %>
          <div class="article-gallery article-gallery--single">
            <img class="gallery-lightbox-trigger" src="<%= soloImg.url %>" alt="<%= soloImg.caption || article.title %>" data-index="0">
          </div>
        <% } else { %>
          <div class="article-gallery article-gallery--masonry">
            <% article.gallery_images.forEach(function (galleryImg, idx) { %>
              <img class="gallery-lightbox-trigger" src="<%= galleryImg.url %>" alt="<%= galleryImg.caption || article.title %>" data-index="<%= idx %>">
            <% }) %>
          </div>
        <% } %>

        <script type="application/json" id="galleryData"><%- JSON.stringify(article.gallery_images).replace(/</g, '\\u003c') %></script>

        <div class="gallery-lightbox" id="galleryLightbox" hidden>
          <button class="gallery-lightbox__close" id="galleryLightboxClose" type="button" aria-label="Close">&times;</button>
          <button class="gallery-lightbox__nav gallery-lightbox__nav--prev" id="galleryLightboxPrev" type="button" aria-label="Previous">&#8249;</button>
          <figure class="gallery-lightbox__figure">
            <img class="gallery-lightbox__image" id="galleryLightboxImage" src="" alt="">
            <figcaption class="gallery-lightbox__caption" id="galleryLightboxCaption"></figcaption>
          </figure>
          <button class="gallery-lightbox__nav gallery-lightbox__nav--next" id="galleryLightboxNext" type="button" aria-label="Next">&#8250;</button>
        </div>
      <% } %>

      <% if (article.audio_file) { %>
        <audio class="article-detail__audio" controls src="<%= article.audio_file %>"></audio>
      <% } %>

      <% if (article.pdf_file) { %>
        <p><a href="<%= article.pdf_file %>" target="_blank" rel="noopener">Download PDF</a></p>
      <% } %>

      <%
        var videoUrl = article.video_url;
        var youtubeId = null;
        if (videoUrl && (videoUrl.indexOf('youtube.com') !== -1 || videoUrl.indexOf('youtu.be') !== -1)) {
          var ytMatch = videoUrl.match(/(?:youtube\.com\/watch\?v=|youtu\.be\/)([A-Za-z0-9_-]{6,})/);
          if (ytMatch) youtubeId = ytMatch[1];
        }
      %>
      <% if (videoUrl && videoUrl.indexOf('facebook.com') !== -1) { %>
        <div class="fb-video-wrapper" style="position:relative; width:100%; max-width:560px; margin:0 auto;">
          <iframe
            class="fb-video-iframe"
            data-fb-url="<%= videoUrl %>"
            src=""
            style="border:none; overflow:hidden; width:100%; aspect-ratio:560/430; display:block;"
            scrolling="no"
            frameborder="0"
            allowfullscreen="true"
            allow="autoplay; clipboard-write; encrypted-media; picture-in-picture; web-share">
          </iframe>
        </div>
      <% } else if (youtubeId) { %>
        <div style="position:relative; width:100%; max-width:560px; aspect-ratio:16/9; margin:0 auto;">
          <iframe
            src="https://www.youtube.com/embed/<%= youtubeId %>"
            style="width:100%; height:100%; border:none;"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen>
          </iframe>
        </div>
      <% } else if (videoUrl) { %>
        <p><a href="<%= videoUrl %>" target="_blank" rel="noopener">Watch video</a></p>
      <% } %>

      <% if (article.author_username) { %>
        <div class="author-box">
          <img class="author-box__photo" src="<%= article.author_photo || '/uploads/defaults/avatar.png' %>" alt="<%= article.author_name %>">
          <div class="author-box__info">
            <h3 class="author-box__name"><a href="/author/<%= encodeURIComponent(article.author_username) %>"><%= article.author_name %></a></h3>
            <% if (article.author_bio) { %>
              <p class="author-box__bio"><%= article.author_bio %></p>
            <% } %>
          </div>
        </div>
      <% } %>

      <div class="article-actions">
        <button class="like-btn" id="likeBtn" type="button" data-slug="<%= article.slug %>" aria-label="Like this article">
          <svg class="like-btn__icon" viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true">
            <path d="M12 21s-6.7-4.35-9.3-8.1C.7 9.7 1.7 6 5 4.7c2-0.8 4 0 5 1.6 1-1.6 3-2.4 5-1.6 3.3 1.3 4.3 5 2.3 8.2C18.7 16.65 12 21 12 21z"/>
          </svg>
          <span class="like-btn__count"><%= article.likes_count || 0 %></span>
        </button>

        <div class="share-links">
          <span class="share-links__label">Share:</span>

          <a class="share-icon share-icon--facebook" href="https://www.facebook.com/sharer/sharer.php?u=<%= encodeURIComponent(canonicalUrl) %>" target="_blank" rel="noopener" aria-label="Share on Facebook">
            <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor" aria-hidden="true"><path d="M22 12.06C22 6.51 17.52 2 12 2S2 6.51 2 12.06c0 5 3.66 9.13 8.44 9.94v-7.03H7.9v-2.91h2.54V9.84c0-2.51 1.49-3.89 3.77-3.89 1.09 0 2.23.2 2.23.2v2.46h-1.26c-1.24 0-1.63.78-1.63 1.57v1.88h2.78l-.45 2.91h-2.33V22c4.78-.81 8.44-4.94 8.44-9.94z"/></svg>
          </a>

          <a class="share-icon share-icon--x" href="https://twitter.com/intent/tweet?url=<%= encodeURIComponent(canonicalUrl) %>&text=<%= encodeURIComponent(article.title) %>" target="_blank" rel="noopener" aria-label="Share on X">
            <svg viewBox="0 0 24 24" width="14" height="14" fill="currentColor" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>

          <a class="share-icon share-icon--linkedin" href="https://www.linkedin.com/sharing/share-offsite/?url=<%= encodeURIComponent(canonicalUrl) %>" target="_blank" rel="noopener" aria-label="Share on LinkedIn">
            <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor" aria-hidden="true"><path d="M19 3A2 2 0 0 1 21 5V19A2 2 0 0 1 19 21H5A2 2 0 0 1 3 19V5A2 2 0 0 1 5 3H19M18.5 18.5V13.2A3.26 3.26 0 0 0 15.24 9.94C14.39 9.94 13.4 10.46 12.92 11.24V10.13H10.13V18.5H12.92V13.57C12.92 12.8 13.54 12.17 14.31 12.17A1.4 1.4 0 0 1 15.71 13.57V18.5H18.5M6.88 8.56A1.68 1.68 0 0 0 8.56 6.88C8.56 5.95 7.81 5.19 6.88 5.19A1.69 1.69 0 0 0 5.19 6.88C5.19 7.81 5.95 8.56 6.88 8.56M8.27 18.5V10.13H5.5V18.5H8.27Z"/></svg>
          </a>

          <button class="share-icon share-icon--instagram" id="shareInstagram" type="button" aria-label="Copy link for Instagram">
            <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor" aria-hidden="true"><path d="M7.8 2h8.4C19.4 2 22 4.6 22 7.8v8.4a5.8 5.8 0 0 1-5.8 5.8H7.8C4.6 22 2 19.4 2 16.2V7.8A5.8 5.8 0 0 1 7.8 2m-.2 2A3.6 3.6 0 0 0 4 7.6v8.8C4 18.39 5.61 20 7.6 20h8.8a3.6 3.6 0 0 0 3.6-3.6V7.6C20 5.61 18.39 4 16.4 4H7.6m9.65 1.5a1.25 1.25 0 0 1 1.25 1.25A1.25 1.25 0 0 1 17.25 8 1.25 1.25 0 0 1 16 6.75a1.25 1.25 0 0 1 1.25-1.25M12 7a5 5 0 1 1 0 10 5 5 0 0 1 0-10m0 2a3 3 0 1 0 0 6 3 3 0 0 0 0-6z"/></svg>
          </button>

          <button class="share-icon share-icon--copy" id="copyLinkBtn" type="button" aria-label="Copy link">
            <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor" aria-hidden="true"><path d="M3.9 12a5 5 0 0 1 5-5h4v2h-4a3 3 0 0 0 0 6h4v2h-4a5 5 0 0 1-5-5m6-1h4v2h-4v-2m5-4h4a5 5 0 0 1 0 10h-4v-2h4a3 3 0 0 0 0-6h-4V7z"/></svg>
          </button>
        </div>
      </div>
    </article>
  </div>

  <aside class="home-sidebar">
    <%- include('../partials/ads-sidebar') %>

    <% if (related.length) { %>
      <h3 class="home-sidebar__heading">Related</h3>
      <ol class="most-read-list">
        <% related.forEach(function (r) { %>
          <li><a href="/article/<%= r.slug %>"><%= r.title %></a></li>
        <% }) %>
      </ol>
    <% } %>
  </aside>
</div>

<script src="/js/article.js" defer></script>
